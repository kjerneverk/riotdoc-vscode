{
  "name": "riotdoc-vscode",
  "displayName": "RiotDoc",
  "description": "AI-assisted document creation with context management",
  "version": "0.1.4-dev.0",
  "publisher": "kjerneverk",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:riotdoc.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "riotdoc",
          "title": "RiotDoc",
          "icon": "$(book)"
        }
      ]
    },
    "views": {
      "riotdoc": [
        {
          "id": "riotdoc.projects",
          "name": "Projects"
        },
        {
          "id": "riotdoc.voice",
          "name": "Voice Profile"
        },
        {
          "id": "riotdoc.guidance",
          "name": "Guidance Sources"
        },
        {
          "id": "riotdoc.assets",
          "name": "Assets"
        },
        {
          "id": "riotdoc.corpus",
          "name": "Corpus"
        }
      ]
    },
    "commands": [
      {
        "command": "riotdoc.createProject",
        "title": "RiotDoc: Create Project"
      },
      {
        "command": "riotdoc.showVoice",
        "title": "RiotDoc: Show Voice Profile"
      },
      {
        "command": "riotdoc.addGuidance",
        "title": "RiotDoc: Add Guidance Source"
      },
      {
        "command": "riotdoc.registerAsset",
        "title": "RiotDoc: Register Asset"
      },
      {
        "command": "riotdoc.searchCorpus",
        "title": "RiotDoc: Search Corpus"
      },
      {
        "command": "riotdoc.assemblePrompt",
        "title": "RiotDoc: Assemble Writing Context"
      },
      {
        "command": "riotdoc.refresh",
        "title": "RiotDoc: Refresh",
        "icon": "$(refresh)"
      }
    ]
  },
  "scripts": {
    "clean": "rm -rf dist out",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "precommit": "npm run build && npm run lint && npm run coverage",
    "prepublishOnly": "npm run clean && npm run build",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.28.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.0.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "publishConfig": {
    "tag": "dev"
  }
}
